# Hostinger / Apache: single-page app — serve index.html for client-side routes.
# Upload with the rest of `dist/` after `npm run build` (Vite copies `public/` into `dist/`).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
